@article{GLX26,
      title={The connected components of affine Deligne-Lusztig varieties}, 
      author={Gleason, Ian and Lim, Dong Gyu and Xu, Yujie},
      year={2026},
      journal   = {Inventiones Mathematicae},
      volume    = {243},
      number    = {2},
      pages     = {805--861},
      doi       = {10.1007/s00222-025-01386-1},
      url       = {https://doi.org/10.1007/s00222-025-01386-1},
      arxiv={2208.07195},
      URL = {https://arxiv.org/pdf/2208.07195.pdf},
      primaryClass={math.NT},
      selected = {true},
      abstract={We compute the connected components of arbitrary parahoric level affine Deligne–Lusztig varieties and local Shimura varieties, thus resolving a folklore conjecture raised in (He in Some results on affine Deligne–Lusztig varieties. YouTube video, 2018; Zhou in Duke Math. J. 169(15):2937–3031, 2020) in full generality (even for non-quasisplit groups). We achieve this by relating them to the connected components of infinite level moduli spaces of $p$-adic shtukas, where we use v-sheaf-theoretic techniques such as the specialization map of kimberlites. Along the way, we give a $p$-adic Hodge-theoretic characterization of HN-irreducibility. As applications, we obtain many results on the geometry of integral models of Shimura varieties of Hodge type at arbitrary stabilizer-parahoric levels. In particular, we deduce new CM lifting results on integral models of Shimura varieties for quasisplit groups at parahoric levels that arise as stabilizer Bruhat–Tits group schemes.}
}

@misc{Lim23,
    title={Nonemptiness criterion of affine Deligne-Lusztig varieties},
    author={Dong Gyu Lim},
    year={2023},
    arxiv={2302.04976},
    URL = {https://arxiv.org/pdf/2302.04976.pdf},
    primaryClass={math.NT},
    selected = {true},
    abstract={Affine Deligne-Lusztig varieties with various level structures show up in the study of Shimura varieties and moduli spaces of shtukas. Among is the Iwahori level structure which is the most refined one. We study the nonemptiness problem of single affine Deligne-Lusztig varieties at Iwahori level in the basic case. Under a genericity condition (the ``shrunken Weyl chambers'' condition), an explicit criterion is known. However, no explicit criterion has been available without the condition even conjecturally. We conjecture a new criterion in full generality, and prove it except for finitely many cases. As an application, the nonemptiness problem in some non-basic cases and a new conjectural dimension formula are discussed.}
}

@misc{Lim23,
    title={Hodge-Newton indecomposability and a combinatorial identity},
    author={Dong Gyu Lim},
    year={2023},
    arxiv={2302.13260},
    URL = {https://arxiv.org/pdf/2302.13260.pdf},
    primaryClass={math.NT},
    selected = {true},
    abstract={We present a simple alternative viewpoint on Hodge-Newton indecomposability, illustrating its explanatory value through a uniform proof of a combinatorial identity arising from affine Deligne-Lusztig varieties with finite Coxeter part.}
}
